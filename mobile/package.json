{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "reanimated": {
    "staticFeatureFlags": {
      "ENABLE_SHARED_ELEMENT_TRANSITIONS": true
    }
  },
  "scripts": {
    "prestart": "node ./scripts/check-node-version.js",
    "prestart:dev-client": "node ./scripts/check-node-version.js",
    "prestart:dev-client:clear": "node ./scripts/check-node-version.js",
    "prestart:dev-client:tunnel": "node ./scripts/check-node-version.js",
    "preios": "node ./scripts/check-node-version.js",
    "preandroid": "node ./scripts/check-node-version.js",
    "start": "expo start",
    "postinstall": "patch-package",
    "start:dev-client": "expo start --dev-client --host lan --port 8081",
    "start:dev-client:clear": "expo start --dev-client --host lan --port 8081 --clear",
    "start:dev-client:local": "expo start --dev-client --host localhost --port 8081",
    "start:dev-client:tunnel": "expo start --dev-client --tunnel --port 8081 --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/app": "^21.8.0",
    "@react-native-firebase/messaging": "^21.8.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/elements": "^2.0.0",
    "@react-navigation/native": "^7.0.0",
    "@shopify/flash-list": "1.7.3",
    "@shopify/react-native-skia": "1.5.0",
    "@supabase/supabase-js": "^2.48.1",
    "android": "^0.0.8",
    "base64-arraybuffer": "^1.0.2",
    "drizzle-orm": "^0.38.3",
    "expo": "~52.0.0",
    "expo-av": "~15.0.1",
    "expo-background-fetch": "~13.0.6",
    "expo-blur": "~14.0.3",
    "expo-build-properties": "~0.13.3",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.2",
    "expo-media-library": "~17.0.6",
    "expo-notifications": "~0.29.14",
    "expo-pip": "^2.0.1",
    "expo-router": "~4.0.22",
    "expo-splash-screen": "~0.29.24",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~2.0.1",
    "expo-symbols": "~0.2.2",
    "expo-system-ui": "~4.0.9",
    "expo-task-manager": "~12.0.6",
    "expo-web-browser": "~14.0.2",
    "ios": "^0.0.1",
    "nativewind": "^2.0.11",
    "node": "^20.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-callkeep": "^4.3.16",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-image-crop-picker": "^0.41.1",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-view-shot": "~4.0.3",
    "react-native-voip-push-notification": "^3.3.3",
    "react-native-web": "~0.19.13",
    "react-native-webrtc": "^124.0.7",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "3.3.2"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~8.0.1",
    "patch-package": "^8.0.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3"
  },
  "private": true
}
