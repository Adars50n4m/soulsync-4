{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "appleTeamId": "7842J35MTZ",
      "supportsTablet": true,
      "bundleIdentifier": "com.soulsync4.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Soul needs camera access for video calls",
        "NSMicrophoneUsageDescription": "Soul needs microphone access for audio and video calls",
        "NSFaceIDUsageDescription": "Allow Soul to use FaceID for secure access",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "processing",
          "voip",
          "picture-in-picture",
          "remote-notification"
        ],
        "LSApplicationQueriesSchemes": [
          "mailto"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.soulsync4.mobile",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.READ_PHONE_NUMBERS",
        "android.permission.ANSWER_PHONE_CALLS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Soul needs camera access for video calls",
          "microphonePermission": "Soul needs microphone access for video calls",
          "recordAudioAndroid": true
        }
      ],
      "expo-sqlite",
      [
        "expo-background-fetch",
        {
          "minimumInterval": 900
        }
      ],
      "./plugins/withCallKit",
      "./plugins/withAndroidCalling",
      "./plugins/withWebSocketFix",
      "expo-local-authentication",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-pip",
      "./plugins/withAndroidPiP",
      "./plugins/withIosPiP",
      [
        "expo-media-library",
        {
          "photosPermission": "Soul needs access to your photos to share them as statuses.",
          "savePhotosPermission": "Soul needs access to save captured media."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca1ec204-cc69-4e84-b822-82c653548e52"
      }
    }
  }
}
